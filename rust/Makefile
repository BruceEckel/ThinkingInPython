# Rust/PyO3 examples for Thinking in Python.
#
# Deliberately isolated from the main build: the repository root's Makefile
# never enters this directory, never runs anything here, and never requires
# a Rust toolchain. Nothing here runs unless you `cd rust && make` yourself.
#
# Needs cargo/rustc (https://rustup.rs) and uv on PATH. `uv run` builds each
# crate through maturin automatically (its pyproject.toml names maturin as
# the build backend) into its own project-local .venv/, so nothing here
# touches the repository root's .venv either.

PY ?= uv run python
CRATES := fastcount

.PHONY: all sync build test clean

all: sync test  ## Sync every crate from the book, then build and run its demo

# Regenerates each crate's src/lib.rs and demo.py from Chapters/. Never
# touches the rest of a crate (Cargo.toml, pyproject.toml, .gitignore,
# .python-version): those are real, hand-maintained project files, not
# generated by this step. Run from the repository root so `uv run` resolves
# its tools/ dependencies the same way the main Makefile does.
sync:  ## Regenerate each crate's src/lib.rs and demo.py from ../Chapters/
	cd .. && $(PY) tools/extract_rust.py --write

# `uv sync` alone builds and installs a crate (via maturin, in release mode)
# without running anything, useful to separate "does it compile" from
# "does the demo pass".
build:  ## Build and install every crate, via maturin, without running its demo
	@for crate in $(CRATES); do \
		echo "-> $$crate"; \
		(cd $$crate && uv sync) || exit 1; \
	done

test:  ## Build every crate and run its demo.py against the real extension
	@for crate in $(CRATES); do \
		echo "-> $$crate/demo.py"; \
		(cd $$crate && uv run python demo.py) || exit 1; \
	done

clean:  ## Remove every crate's target/ and .venv/ (does not touch the book)
	@for crate in $(CRATES); do rm -rf $$crate/target $$crate/.venv; done
